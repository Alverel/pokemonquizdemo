{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "npx prisma db push --accept-data-loss && node src/index.js",
    "healthcheckPath": "/api/quiz/questions",
    "restartPolicyType": "ON_FAILURE"
  }
}
